# 简历平台后端配置模板
# 复制为 .env 并填入真实值

# ===== 认证 =====
JWT_SECRET=your-jwt-secret-here

# ===== 数据库 =====
DATABASE_URL=sqlite:///./resume_dev.db

# ===== PayJS 支付 =====
PAYJS_MCHID=
PAYJS_KEY=
PAYJS_NOTIFY_URL=

# ===== S3 存储（群晖 NAS） =====
S3_ENDPOINT=https://your-nas-tailscale-ip:9000
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=resume-deliveries
S3_REGION=us-east-1
