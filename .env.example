# ============================================
# 简历平台环境变量模板
# ============================================

# --- 数据库 ---
DATABASE_URL=sqlite:///./resume_dev.db

# --- JWT ---
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- 应用 ---
APP_BASE_URL=http://localhost:5173

# --- 微信 OAuth（需 ICP 备案后申请） ---
WECHAT_APP_ID=TODO_WECHAT_APP_ID
WECHAT_APP_SECRET=TODO_WECHAT_APP_SECRET
WECHAT_REDIRECT_URI=http://localhost:5173/auth/callback/wechat

# --- 支付宝 OAuth（需 ICP 备案后申请） ---
ALIPAY_APP_ID=TODO_ALIPAY_APP_ID
ALIPAY_PRIVATE_KEY=TODO_ALIPAY_PRIVATE_KEY
ALIPAY_REDIRECT_URI=http://localhost:5173/auth/callback/alipay

# --- S3 存储 ---
S3_ENDPOINT=http://100.64.0.12:9000
S3_BUCKET=resume-deliveries
S3_ENABLED=true
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
